<?xml version="1.0" encoding="UTF-8"?>
<Context>
    <!-- Configuração do Pool de Conexões JNDI no Tomcat -->
    <Resource name="jdbc/DeliveryDB" 
              auth="Container" 
              type="javax.sql.DataSource"
              driverClassName="org.sqlite.JDBC"
              url="jdbc:sqlite:${catalina.base}/delivery.db"
              username="" 
              password=""
              maxTotal="10" 
              maxIdle="2" 
              maxWaitMillis="10000"/>
</Context>